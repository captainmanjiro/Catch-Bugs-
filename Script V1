-- ============================================================
local function teleportToNPC(modelName)
    local npcsFolder = workspace:FindFirstChild("NPCS")
    if not npcsFolder then
        Fluent:Notify({ Title = "Teleport", Content = "NPCS folder not found!", Duration = 3 })
        return
    end
    local model = npcsFolder:FindFirstChild(modelName)
    if model then
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if hrp and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, 3, 4)
            local info = NPCInfo[modelName]
            Fluent:Notify({ Title = "Teleported!", Content = "Went to " .. (info and info.display or modelName), Duration = 2 })
        end
    else
        Fluent:Notify({ Title = "Teleport", Content = modelName .. " not found!", Duration = 3 })
    end
end

