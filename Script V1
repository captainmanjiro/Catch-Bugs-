--  BUY FUNCTIONS
-- ============================================================
local function buyNet(netID)
    local ok, result = pcall(function() return BuyNetFunc:InvokeServer(netID) end)
    if ok then
        if type(result) == "table" then return result.success, result.message end
        return result == true, "Failed"
    end
    return false, tostring(result)
end

local function buyBait(baitID)
    local ok, result = pcall(function() return BuyBaitFunc:InvokeServer(baitID) end)
    if ok then
        if type(result) == "table" then return result.success ~= false, result.message end
        return true, nil
    end
    return false, tostring(result)
end

local function buyPotion(potionType)
    local ok, err = pcall(function() BuyPotionFunc:InvokeServer(potionType) end)
    if not ok then warn("[Fisch Hub] BuyPotion error: " .. tostring(err)) end
end

