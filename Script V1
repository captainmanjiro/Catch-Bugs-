local ESPData = {}

local function getPlayerHRP()
    local char = Player.Character
    if char then return char:FindFirstChild("HumanoidRootPart") end
end

local function createESPBillboard(model, modelName)
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if ESPData[modelName] then return end
    local info = NPCInfo[modelName] or { display = modelName, purpose = "Unknown" }
    local bb = Instance.new("BillboardGui")
    bb.Name = "FischHubNPCESP"
    bb.Size = UDim2.new(0, 220, 0, 70)
    bb.StudsOffset = Vector3.new(0, 4, 0)
    bb.AlwaysOnTop = true
    bb.Adornee = hrp
    bb.Parent = CoreGui
    local frame = Instance.new("Frame")
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.4
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.Parent = bb
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    local function makeLabel(text, color, size, pos)
        local lbl = Instance.new("TextLabel")
        lbl.Text = text
        lbl.TextColor3 = color
        lbl.TextStrokeTransparency = 0
        lbl.BackgroundTransparency = 1
        lbl.Size = size
        lbl.Position = pos
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 11
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = frame
        return lbl
    end
    makeLabel("👤 " .. info.display, Color3.fromRGB(0,255,128), UDim2.new(1,-6,0.38,0), UDim2.new(0,3,0,2))
    makeLabel("📋 " .. info.purpose, Color3.fromRGB(255,220,50), UDim2.new(1,-6,0.3,0), UDim2.new(0,3,0.36,0))
    local distLbl = makeLabel("📍 - studs", Color3.fromRGB(180,180,255), UDim2.new(1,-6,0.3,0), UDim2.new(0,3,0.68,0))
    distLbl.Name = "DistLabel"
    ESPData[modelName] = { billboard = bb, distLabel = distLbl, hrp = hrp }
end

local function clearAllESP()
    for _, data in pairs(ESPData) do data.billboard:Destroy() end
    ESPData = {}
end

local function setupAllESP()
    local npcsFolder = workspace:FindFirstChild("NPCS")
    if not npcsFolder then return end
    for _, model in pairs(npcsFolder:GetChildren()) do
        if model:IsA("Model") then createESPBillboard(model, model.Name) end
    end
    npcsFolder.ChildAdded:Connect(function(model)
        if model:IsA("Model") and getgenv().NPCespOn then
            task.wait(0.5)
            createESPBillboard(model, model.Name)
        end
    end)
    npcsFolder.ChildRemoved:Connect(function(model)
        if model:IsA("Model") then
            if ESPData[model.Name] then
                ESPData[model.Name].billboard:Destroy()
                ESPData[model.Name] = nil
            end
        end
    end)
end

